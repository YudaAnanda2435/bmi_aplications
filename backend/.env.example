# Template environment untuk DietCare API.
# Salin file ini menjadi `.env`, lalu sesuaikan nilainya untuk komputer lokal.
# `.env` adalah konfigurasi aktif lokal. Jangan commit `.env` jika project memakai git.

APP_NAME=DietCare API
APP_ENV=development

# Default XAMPP biasanya memakai user root tanpa password.
DATABASE_URL=mysql+pymysql://root:@localhost:3306/sinagar_dietcare

# Ganti SECRET_KEY di environment non-development.
SECRET_KEY=change-this-secret-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

MODEL_PATH=ml_models/naive_bayes_obesity_model_final.pkl
MODEL_METADATA_PATH=ml_models/model_metadata_final.json

BACKEND_CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Admin default hanya untuk development.
# Password akan disimpan sebagai hash bcrypt di database.
DEFAULT_ADMIN_NAME=Administrator
DEFAULT_ADMIN_EMAIL=admin@sinagar.local
DEFAULT_ADMIN_PASSWORD=change-this-admin-password
